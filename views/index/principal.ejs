<!-- DASHBOARD -->
<section class="dashboard-section" id="dashboard">
  <div class="container">
    <div class="text-center mb-5 fade-up">
      <div class="section-eyebrow justify-content-center">Dashboard</div>
      <h2 class="section-title">Painel de <span>Monitoramento</span></h2>
    </div>

    <!-- Row 1 -->
    <div class="row g-4 mb-4">
      <!-- Chart 1 -->
      <div class="col-12 col-md-6 fade-up delay-1">
        <div class="chart-card">
          <div class="chart-header">
            <div>
              <div class="chart-title">Distribuição de Fluxo por Hora</div>
              <div class="chart-subtitle">Contagem bidirecional ao longo do dia</div>
            </div>
            <div class="chart-toggle">
              <button class="toggle-btn active">Hoje</button>
              <button class="toggle-btn">Semana</button>
              <button class="toggle-btn">Mês</button>
            </div>
          </div>
          <div class="chart-canvas-wrap mt-3">
            <canvas id="chart1" height="180"></canvas>
          </div>
        </div>
      </div>
      <!-- Chart 2 -->
      <div class="col-12 col-md-6 fade-up delay-2">
        <div class="chart-card">
          <div class="chart-header">
            <div>
              <div class="chart-title">Variabilidade Semanal</div>
              <div class="chart-subtitle">Amplitude da ocupação média por dia da semana</div>
            </div>
            <div class="chart-toggle">
              <button class="toggle-btn active">Atual</button>
              <button class="toggle-btn">Anterior</button>
              <button class="toggle-btn">Mês</button>
            </div>
          </div>
          <div class="chart-canvas-wrap mt-3">
            <canvas id="chart2" height="180"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- Row 2 -->
    <div class="row g-4 mb-4">
      <!-- Chart 3 -->
      <div class="col-12 col-md-6 fade-up delay-1">
        <div class="chart-card">
          <div class="chart-header">
            <div>
              <div class="chart-title">Entradas vs. Saídas</div>
              <div class="chart-subtitle">Comparativo do fluxo de pessoas por semana</div>
            </div>
            <div class="chart-toggle">
              <button class="toggle-btn active">Hoje</button>
              <button class="toggle-btn">Semana</button>
              <button class="toggle-btn">Mês</button>
            </div>
          </div>
          <div class="chart-canvas-wrap mt-3">
            <canvas id="chart3" height="180"></canvas>
          </div>
        </div>
      </div>
      <!-- Chart 4: Donut -->
      <div class="col-12 col-md-6 fade-up delay-2">
        <div class="chart-card">
          <div class="chart-header">
            <div>
              <div class="chart-title">Ocupação por Setor</div>
              <div class="chart-subtitle">Distribuição de ocupação por área por semana</div>
            </div>
            <div class="chart-toggle">
              <button class="toggle-btn active">Hoje</button>
              <button class="toggle-btn">Semana</button>
              <button class="toggle-btn">Mês</button>
            </div>
          </div>
          <div class="chart-canvas-wrap mt-3 d-flex justify-content-center">
            <canvas id="chart4" height="180" style="max-width:280px;"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- Row 3: Full width line chart -->
    <div class="row g-4">
      <div class="col-12 fade-up delay-1">
        <div class="chart-card">
          <div class="chart-header">
            <div>
              <div class="chart-title">Tendência de Ocupação em Tempo Real</div>
              <div class="chart-subtitle">Monitoramento contínuo da ocupação ao longo do tempo</div>
            </div>
            <div class="chart-toggle">
