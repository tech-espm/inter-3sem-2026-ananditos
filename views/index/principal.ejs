              <button class="toggle-btn">Semana</button>
              <button class="toggle-btn">30m</button>
            </div>
          </div>
          <div class="chart-canvas-wrap mt-3">
            <canvas id="chart5" height="100"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ESTRUTURA DE DADOS -->
<section class="dados-section" id="dados">
  <div class="container">
    <div class="text-center mb-5 fade-up">
      <div class="section-eyebrow justify-content-center">Dados</div>
      <h2 class="section-title">Estrutura de <span>Dados</span></h2>
      <p class="section-desc">Conheça os campos utilizados na coleta e análise do fluxo de pessoas.</p>
    </div>
    <div class="fade-up delay-1">
      <div class="chart-card">
        <table class="table-custom">
          <thead>
            <tr>
              <th>Campo</th>
              <th>Tipo</th>
              <th>Descrição</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>ID_Sensor</td>
              <td><span class="badge-type badge-varchar">VARCHAR</span></td>
              <td>Identificador único do dispositivo de captura.</td>
            </tr>
            <tr>
              <td>Timestamp</td>
              <td><span class="badge-type badge-datetime">DATETIME</span></td>
              <td>Data e hora exata do registro do evento.</td>
            </tr>
            <tr>
              <td>Entradas</td>
              <td><span class="badge-type badge-int">INT</span></td>
              <td>Contagem numérica do fluxo de entrada.</td>
            </tr>
            <tr>
              <td>Saídas</td>
              <td><span class="badge-type badge-int">INT</span></td>
              <td>Contagem numérica do fluxo de saída.</td>
            </tr>
            <tr>
              <td>Ocupação_Atual</td>
              <td><span class="badge-type badge-int">INT</span></td>
              <td>Saldo calculado de pessoas no recinto.</td>
            </tr>
            <tr>
              <td>Status_Alerta</td>
              <td><span class="badge-type badge-varchar">BOOLEAN</span></td>
              <td>Indicador para níveis críticos de lotação.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

